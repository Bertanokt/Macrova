# Macrova — Örnek .env dosyası
# Gerçek değerleri .env'e kopyala, asla commit'leme!

# JWT — En az 32 karakterli rastgele string (openssl rand -hex 32)
JWT_SECRET=buraya-en-az-32-karakterli-rastgele-bir-string-yaz
JWT_ALGORITHM=HS256

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# CORS — Virgülle ayrılmış origin listesi (production'da)
ALLOWED_ORIGINS=http://localhost:3000,https://macrova.app

# Ortam: development | production
ENVIRONMENT=development
